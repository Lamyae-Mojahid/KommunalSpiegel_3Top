# KommunalSpiegel v6 · API-Keys
# Kopieren nach .env und ausfüllen

# ── SICHT 3: Google Street View Metadata ───────────────────────────
# Erstellen: https://console.cloud.google.com
# → Neues Projekt → APIs & Services → Street View Static API aktivieren
# → Anmeldedaten → API-Schlüssel erstellen
# Kosten: 0 € (Metadata-Endpoint ist kostenlos)
GOOGLE_MAPS_API_KEY=

# ── SICHT 8: Meta Graph API ─────────────────────────────────────────
# Erstellen: https://developers.facebook.com
# → My Apps → Create App → Graph API Explorer → Access Token generieren
# Hinweis: Short-Lived Token (60 Tage), für Prod: Long-Lived Token
META_ACCESS_TOKEN=

# ── SICHT 1: Claude API (IGEK PDF-Parsing) ──────────────────────────
# Erstellen: https://console.anthropic.com → API Keys
# Kosten: ~0,05-0,20 € pro PDF (nur manuell ausgelöst)
ANTHROPIC_API_KEY=

# ── Supabase (optional) ──────────────────────────────────────────────
# Erstellen: https://supabase.com → neues Projekt
# Ohne Supabase läuft alles lokal als JSON-Datei
SUPABASE_URL= 
SUPABASE_SERVICE_ROLE_KEY=

# ── Kein Key nötig für ──────────────────────────────────────────────
# Sicht 4: BNetzA Ladesäulenregister XLSX (kostenlos, öffentlich)
#   Download: https://www.bundesnetzagentur.de/DE/Fachthemen/ElektrizitaetundGas/E-Mobilitaet/start.html
#   Verwende: python sync_alle_sichten.py --sicht 4 --file ~/Downloads/Ladesaeulenregister.xlsx
#
# Sicht 5: BNetzA Breitbandatlas XLSX (kostenlos, öffentlich, halbjährlich)
#   Download: https://gigabitgrundbuch.bund.de/GIGA/DE/Downloads_Suche/start.html
#             → Filter: Festnetz + Tabelle + aktuell
#   Verwende: python sync_alle_sichten.py --sicht 5 --file ~/Downloads/bba_12_2025.xlsx
#
# Sicht 6: BNetzA Mobilfunk-Monitoring XLSX (kostenlos, öffentlich, halbjährlich)
#   Download: https://gigabitgrundbuch.bund.de/GIGA/DE/Downloads_Suche/start.html
#             → Filter: Mobilfunk + Tabelle + aktuell
#   Verwende: python sync_alle_sichten.py --sicht 6 --file ~/Downloads/Auswertung_Mobilfunkmonitoring.xlsx
#
# Sicht 2+9+10: OSM Overpass API (kostenlos, kein Key, täglich)
#   Läuft automatisch ohne Konfiguration
